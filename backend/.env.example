# Copy this file to backend/.env and fill in the values before first start.

# Admin user created automatically on first start (promoted to role "admin").
SEED_USER_EMAIL=admin@example.local
SEED_USER_PASSWORD=admin1234

# Secret used by better-auth to sign sessions — generate a random value.
BETTER_AUTH_SECRET=change-me

# Base URL better-auth uses to build callback/cookie URLs. Default fits local dev.
BETTER_AUTH_URL=http://localhost:3001

# Comma-separated origins allowed to call the auth API.
TRUSTED_ORIGINS=http://localhost:3000,http://localhost:3001
