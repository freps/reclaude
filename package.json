{
  "name": "reclaude",
  "private": true,
  "scripts": {
    "predev": "lsof -ti:3000,3001 | xargs kill -9 2>/dev/null || true",
    "dev": "concurrently -n fe,be -c blue,green \"bun run --cwd frontend dev\" \"bun run --cwd backend dev\"",
    "dev:frontend": "bun run --cwd frontend dev",
    "dev:backend": "bun run --cwd backend dev",
    "build": "bun run --cwd frontend build",
    "start": "bun run --cwd backend src/index.ts"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
