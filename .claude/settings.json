{
  "permissions": {
    "allow": [
      "Bash(bun install)",
      "Bash(bun install:*)",
      "Bash(bun run lint:*)",
      "Bash(bun run lint)",
      "Bash(bun run format:*)",
      "Bash(bun run format)",
      "Bash(bun run typecheck)",
      "Bash(bun run build)",
      "Bash(bun test)",
      "Bash(bun test:*)",
      "Bash(git status)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git branch:*)",
      "Bash(git checkout:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(npm view *)",
      "Bash(git check-ignore *)",
      "Bash(bun add *)",
      "Bash(bun search *)",
      "Bash(npm search *)",
      "Bash(npm info *)",
      "Bash(bun run *)",
      "Bash(npm show *)",
      "Bash(git merge *)",
      "Bash(git stash *)",
      "mcp__chrome-devtools__*"
    ],
    "deny": [
      "Bash(git push:*)",
      "Bash(bun run dev)",
      "Bash(bun run dev:*)",
      "Bash(bun run start)",
      "Bash(git reset --hard *)",
      "Bash(git clean *)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR/.claude/hooks/lint-fix.sh\"",
            "timeout": 180,
            "statusMessage": "lint:fix (frontend/backend)"
          },
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR/.claude/hooks/steering-dirty.sh\"",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR/.claude/hooks/update-steering.sh\"",
            "timeout": 620,
            "statusMessage": "Steering: Component-/Baustein-Kapitel aktualisieren",
            "async": true
          }
        ]
      }
    ]
  },
  "worktree": {
    "bgIsolation": "none"
  }
}
